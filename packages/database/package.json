{
  "name": "@repo/database",
  "version": "1.0.0",
  "private": true,

  "main": "./dist/index.js",

  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js"
  },

  "scripts": {
    "db:migrate": "dotenv -- drizzle-kit migrate",
    "db:generate": "dotenv -- drizzle-kit generate",
    "dev": "dotenv -- drizzle-kit studio",
    "db:seed": "dotenv -- tsx seed/index.ts",
    "build": "tsup ./index.ts ./schema.ts --format cjs"
  },

  "dependencies": {
    "@repo/typescript-config": "workspace:*",

    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.1",
    "pg": "^8.16.3",
    "tsup": "^8.5.1",
    "zod": "^4.3.5"
  },

  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}